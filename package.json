{
  "name": "medverify-india",
  "version": "1.0.0",
  "description": "MedVerify India — Full-stack MERN app to fight fake medicines",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm start --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --prefix frontend",
    "seed": "node backend/utils/seedData.js",
    "seed:1000": "node backend/utils/seed1000Medicines.js",
    "start": "npm start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "nodemailer": "^8.0.3"
  }
}
