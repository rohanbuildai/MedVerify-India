# Environment Configuration for MedVerify India

NODE_ENV=development
PORT=5000

# MongoDB Connection String
# Replace with your MongoDB URI or use a service like MongoDB Atlas
MONGODB_URI=mongodb://localhost:27017/medverifyindia

# JWT Configuration
JWT_SECRET=medverifyindia_secret_key_change_in_production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Email Configuration (for nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=MedVerify India <noreply@medverify.in>

# Client URL
CLIENT_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Admin Configuration
ADMIN_EMAIL=admin@medverify.in
ADMIN_SECRET_KEY=admin_secret_key_change_in_production

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads