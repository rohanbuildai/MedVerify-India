# Environment Variables for MedVerify India
# Copy this to .env and fill in your values

# Node Environment
NODE_ENV=development
PORT=5000

# MongoDB Connection (Use Atlas URI or local)
# For local: mongodb://localhost:27017/medverify
# For Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/medverify
MONGODB_URI=mongodb://localhost:27017/medverify

# JWT Configuration
JWT_SECRET=medverify_jwt_secret_key_change_in_production
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Email Configuration (for nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@medverify.in

# Client URL (for frontend)
CLIENT_URL=http://localhost:3000

# Admin Configuration
ADMIN_EMAIL=admin@medverify.in
ADMIN_SECRET_KEY=admin_secret_key_change_in_production